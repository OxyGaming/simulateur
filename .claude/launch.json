{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Start (production build)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000
    },
    {
      "name": "Icon Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "http-server", "tmp/icon-preview", "-p", "3030", "-c-1", "-s"],
      "port": 3030,
      "autoPort": true
    }
  ]
}
