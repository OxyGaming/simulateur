# ──────────────────────────────────────────────────────────────────────────────
# Simulateur PRS — variables d'environnement.
# Copier ce fichier en .env et adapter les valeurs.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Dev local ────────────────────────────────────────────────────────────────
# Chemin de la DB relatif au projet (créé automatiquement).
DATABASE_URL=file:./data/app.db

# Secret de signature des cookies de session (iron-session).
# PROD : générer avec `openssl rand -hex 32` (≥ 32 caractères, imprévisible).
SESSION_SECRET=change-me-please-at-least-32-chars-long

# URL publique de l'application (utile pour les liens absolus).
PUBLIC_URL=http://localhost:3000

# ─── Production (docker-compose) ──────────────────────────────────────────────
# Ne commitez JAMAIS un .env de prod ; ce fichier reste un exemple.
#
# Décommentez et adaptez pour un déploiement self-hosted :
#
# DATABASE_URL=file:/data/app.db
# SESSION_SECRET=<générer avec `openssl rand -hex 32`>
# PUBLIC_URL=https://prs.mondomaine.fr
#
# DOMAIN=prs.mondomaine.fr                 # utilisé par Caddy pour le certificat
# ACME_EMAIL=admin@mondomaine.fr           # email Let's Encrypt
#
# ─── Litestream : réplica S3-compatible optionnel (OVH Object Storage, B2, …) ─
# Décommentez le bloc s3 dans litestream.yml ET renseignez ces credentials.
# LITESTREAM_ACCESS_KEY_ID=<AK>
# LITESTREAM_SECRET_ACCESS_KEY=<SK>
